{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"verbatimModuleSyntax": true,
		"types": ["node", "vitest/globals"]
	},
	"include": ["extensions/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
